# Continuous Dev Loop 配置文件 v2.0
# 复制到项目目录后根据需要修改

# ============================================
# 目录配置
# ============================================
STATE_DIR=".dev-state"

# ============================================
# 会话控制
# ============================================
MAX_TURNS=50                    # 单次会话最大轮次
MAX_PARALLEL_SESSIONS=3         # 最大并行会话数 (预留)

# ============================================
# 限流保护 (重要!)
# ============================================
MIN_SESSION_INTERVAL=60         # 最小会话间隔 (秒)
MAX_SESSION_INTERVAL=120        # 最大会话间隔 (秒) - 随机化防止限流
RATE_LIMIT_WAIT=300             # 限流后等待时间 (秒)
RATE_LIMIT_BACKOFF=1.5          # 限流退避倍数

# ============================================
# 错误处理
# ============================================
MAX_RETRIES=3                   # 单任务最大重试次数
RETRY_BASE_DELAY=60             # 重试基础延迟 (秒)
MAX_CONSECUTIVE_ERRORS=5        # 连续错误次数上限

# ============================================
# 心跳与断点
# ============================================
HEARTBEAT_TIMEOUT=600           # 心跳超时判定 (秒)
CHECKPOINT_INTERVAL=300         # 断点保存间隔 (秒)

# ============================================
# 告警配置 (可选)
# ============================================
ALERT_WEBHOOK=""                # Slack/钉钉 webhook URL
ALERT_EMAIL=""                  # 告警邮箱

# ============================================
# 调试
# ============================================
DEBUG_MODE=false
