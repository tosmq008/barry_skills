#!/bin/bash
# continuous-dev - 7×24 持续开发守护脚本 v3.3
# 自动判断项目状态，统一入口

VERSION="3.11.0"
SCRIPT_NAME="continuous-dev"

# 配置
STATE_DIR=".dev-state"
MAX_TURNS=50
MIN_INTERVAL=60
MAX_INTERVAL=120
RATE_LIMIT_WAIT=300
MAX_ERRORS=5
SESSION_TIMEOUT=1800  # 会话超时 30 分钟
HEARTBEAT_TIMEOUT=1800  # 心跳超时 30 分钟
CLAUDE_MODEL="${CLAUDE_MODEL:-claude-opus-4-5-20251101}"  # 默认使用 Opus 4.5

# 路径
PROJECT_DIR="$(pwd)"
STATE_FILE="$PROJECT_DIR/$STATE_DIR/state.json"
PID_FILE="$PROJECT_DIR/$STATE_DIR/daemon.pid"
LOG_DIR="$PROJECT_DIR/$STATE_DIR/logs"
REQUIREMENT_FILE="$PROJECT_DIR/$STATE_DIR/requirement.txt"

# ============================================
# 工具函数
# ============================================

get_json() {
    python3 -c "import json; print(json.load(open('$STATE_FILE'))$1)" 2>/dev/null
}

set_json() {
    python3 << EOF
import json
with open('$STATE_FILE', 'r') as f:
    d = json.load(f)
$1
with open('$STATE_FILE', 'w') as f:
    json.dump(d, f, indent=2, ensure_ascii=False)
EOF
}

# 检测项目状态
detect_project_state() {
    # 返回: new_empty | new_with_docs | existing_state | running
    
    # 1. 检查是否已在运行
    if [ -f "$PID_FILE" ] && ps -p "$(cat "$PID_FILE")" &>/dev/null; then
        echo "running"
        return
    fi
    
    # 2. 检查是否有状态文件（之前用过 continuous-dev）
    if [ -f "$STATE_FILE" ]; then
        echo "existing_state"
        return
    fi
    
    # 3. 检查项目是否有 PRD 文档（最可靠的标志）
    if [ -d "docs/prd" ] && ls docs/prd/*.md &>/dev/null; then
        echo "new_with_docs"
        return
    fi
    
    # 4. 检查是否有明确的需求文档（不包括通用的 README.md）
    if [ -f "PRD.md" ] || [ -f "requirements.md" ] || [ -f "需求.md" ] || [ -f "REQUIREMENTS.md" ]; then
        echo "new_with_docs"
        return
    fi
    
    # 5. 检查是否有代码目录（有实际代码的项目）
    if [ -d "src" ] || [ -d "client" ] || [ -d "admin" ] || [ -d "website" ] || [ -d "app" ]; then
        echo "new_with_docs"
        return
    fi
    
    # 6. 空项目（README.md 不算有文档）
    echo "new_empty"
}

# ============================================
# 命令
# ============================================

cmd_help() {
    cat << EOF
$SCRIPT_NAME v$VERSION - 7×24 持续开发守护脚本

用法: 
  $SCRIPT_NAME start [需求描述]
  $SCRIPT_NAME <command>

命令:
  start [requirement]  启动（自动判断项目状态）
  stop                 停止守护进程
  pause                暂停（完成当前会话后）
  status               查看状态
  logs                 实时日志
  reset                重置

自动判断逻辑:
  - 已在运行 → 提示已运行
  - 有 .dev-state/ → 从断点继续（包括 paused 状态）
  - 有 docs/prd/ 或代码 → 基于现有项目继续
  - 空项目 → 需要传入需求描述

示例:
  # 空项目，从需求开始
  $SCRIPT_NAME start "一个待办事项App，支持增删改查"
  
  # 已有项目或暂停后继续
  $SCRIPT_NAME start

EOF
}

cmd_start() {
    local requirement="$1"
    local project_name="$(basename "$PROJECT_DIR")"
    
    # 检查依赖
    command -v python3 &>/dev/null || { echo "❌ 需要 python3"; exit 1; }
    command -v claude &>/dev/null || { echo "❌ 需要 claude CLI"; exit 1; }
    
    # 自动判断状态
    local state=$(detect_project_state)
    
    case "$state" in
        running)
            local pid=$(cat "$PID_FILE")
            echo "⚠️  已在运行 (PID: $pid)"
            echo "   使用 '$SCRIPT_NAME status' 查看状态"
            echo "   使用 '$SCRIPT_NAME stop' 停止"
            exit 1
            ;;
            
        existing_state)
            echo "🔄 检测到断点，从上次继续..."
            project_name=$(get_json "['project']['name']")
            # 如果是 paused 状态，自动恢复为 continue
            local current_status=$(get_json "['status']")
            if [ "$current_status" = "paused" ]; then
                echo "   (从暂停状态恢复)"
                set_json "d['status']='continue'"
            fi
            _do_start "$project_name" ""
            ;;
            
        new_with_docs)
            echo "📂 检测到现有项目文档，基于现有内容继续..."
            _init_state "$project_name" ""
            _do_start "$project_name" ""
            ;;
            
        new_empty)
            if [ -z "$requirement" ]; then
                echo "❌ 空项目需要提供需求描述"
                echo ""
                echo "用法: $SCRIPT_NAME start \"需求描述\""
                echo ""
                echo "示例:"
                echo "  $SCRIPT_NAME start \"一个待办事项App，支持创建、完成、删除任务\""
                exit 1
            fi
            echo "🆕 新项目，从需求开始..."
            _init_state "$project_name" "$requirement"
            _do_start "$project_name" "$requirement"
            ;;
    esac
}

_init_state() {
    local name="$1"
    local requirement="$2"
    
    mkdir -p "$PROJECT_DIR/$STATE_DIR"/{logs,checkpoints}
    local ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    
    if [ -n "$requirement" ]; then
        echo "$requirement" > "$REQUIREMENT_FILE"
    fi
    
    cat > "$STATE_FILE" << EOF
{
  "version": "$VERSION",
  "project": {"name": "$name", "path": "$PROJECT_DIR"},
  "workflow": {"current_phase": "development", "iteration": 1},
  "status": "ready",
  "exit_reason": null,
  "current_task": {"name": "初始化", "checkpoint": null},
  "sessions": {"count": 0},
  "last_heartbeat": "$ts",
  "errors": []
}
EOF
}

_do_start() {
    local name="$1"
    local requirement="$2"
    
    echo "🚀 启动持续开发: $name"
    echo "   项目目录: $PROJECT_DIR"
    
    # 启动守护进程
    _start_daemon &
    local pid=$!
    echo $pid > "$PID_FILE"
    
    sleep 2
    if ps -p $pid &>/dev/null; then
        echo ""
        echo "✅ 已启动 (PID: $pid)"
        echo ""
        echo "常用命令:"
        echo "  $SCRIPT_NAME status  查看状态"
        echo "  $SCRIPT_NAME logs    实时日志"
        echo "  $SCRIPT_NAME stop    停止"
    else
        echo "❌ 启动失败"
        tail -5 "$LOG_DIR/daemon.log" 2>/dev/null
        exit 1
    fi
}

_start_daemon() {
    exec >> "$LOG_DIR/daemon.log" 2>&1
    
    _log "=========================================="
    _log "守护进程启动 v$VERSION"
    _log "=========================================="
    
    trap '_log "收到终止信号"; exit 0' SIGTERM SIGINT
    
    local errors=0
    local heartbeat_check_interval=60  # 每 60 秒检查一次心跳
    local last_heartbeat_check=0
    
    while true; do
        [ ! -f "$STATE_FILE" ] && { _log "ERROR: 状态文件丢失"; sleep 60; continue; }
        
        local status=$(get_json "['status']")
        local current_time=$(date +%s)
        
        case "$status" in
            ready|continue)
                _run_session
                local ret=$?
                [ $ret -eq 2 ] && _handle_rate_limit
                [ $ret -ne 0 ] && [ $ret -ne 2 ] && errors=$((errors+1))
                [ $ret -eq 0 ] && errors=0
                [ $errors -ge $MAX_ERRORS ] && { _log "ERROR: 连续错误过多"; exit 1; }
                
                local wait=$((MIN_INTERVAL + RANDOM % (MAX_INTERVAL - MIN_INTERVAL + 1)))
                _log "等待 ${wait}s"
                sleep $wait
                ;;
            running)
                # 检查是否有 continuous-dev 启动的 claude 进程在运行
                # 通过检查父进程是否是当前守护进程来判断
                local my_pid=$$
                local claude_running=""
                for pid in $(pgrep -u "$(whoami)" -x "claude" 2>/dev/null); do
                    local ppid=$(ps -o ppid= -p $pid 2>/dev/null | tr -d ' ')
                    if [ "$ppid" = "$my_pid" ]; then
                        claude_running="$pid"
                        break
                    fi
                done
                
                if [ -z "$claude_running" ]; then
                    # 没有属于当前守护进程的 claude 进程，但状态是 running，说明进程异常退出
                    _log "WARN: 状态为 running 但无关联 claude 进程，重置状态"
                    set_json "d['status']='continue'; d['exit_reason']='process_lost'"
                    sleep 5
                    continue
                fi
                
                # 检查心跳超时
                if [ $((current_time - last_heartbeat_check)) -gt $heartbeat_check_interval ]; then
                    last_heartbeat_check=$current_time
                    if check_heartbeat_timeout; then
                        _log "心跳超时，强制重启会话..."
                        set_json "d['status']='continue'; d['exit_reason']='heartbeat_timeout'"
                        set_json "d['errors'].append({'type': 'heartbeat_timeout', 'session': d['sessions']['count'], 'time': '$(date -u +%Y-%m-%dT%H:%M:%SZ)'})"
                        # 只杀死属于当前守护进程的 claude 进程
                        if [ -n "$claude_running" ]; then
                            _log "杀死 claude 进程: $claude_running"
                            kill -TERM $claude_running 2>/dev/null || true
                            sleep 3
                            kill -9 $claude_running 2>/dev/null || true
                        fi
                        sleep 5
                    fi
                fi
                sleep 30
                ;;
            paused)
                _log "已暂停"
                sleep 60
                ;;
            completed)
                _log "🎉 全部完成！"
                exit 0
                ;;
            *)
                sleep 30
                ;;
        esac
    done
}

_log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

_run_session() {
    local phase=$(get_json "['workflow']['current_phase']")
    local project_name=$(get_json "['project']['name']")
    local session_count=$(get_json "['sessions']['count']")
    _log "启动会话 #$((session_count+1)) - 阶段: $phase"
    
    set_json "d['status']='running'; d['sessions']['count']=d['sessions'].get('count',0)+1"
    
    # 读取需求描述（仅作为备用）
    local requirement=""
    [ -f "$REQUIREMENT_FILE" ] && requirement=$(cat "$REQUIREMENT_FILE")
    
    # 构建 prompt
    local prompt="你正在 7×24 持续开发模式下工作。

## 第一步：读取工作规范
cat ~/.claude/skills/continuous-dev-loop/SKILL.md

## 项目信息
- 项目名称: $project_name
- 项目目录: $PROJECT_DIR
- 状态文件: $STATE_FILE

## 第二步：检查项目现有内容（必须先执行）
ls -la docs/prd/*.md 2>/dev/null
ls -la PRD.md README.md requirements.md 2>/dev/null
ls -la src/ client/ admin/ website/ 2>/dev/null
cat $STATE_FILE

## 备用需求描述（仅当项目完全为空时使用）
$requirement

## 执行要求
1. 优先基于现有文档和代码继续
2. 只有项目完全为空时才使用需求描述从零开始
3. 每完成一步更新 state.json
4. 接近轮次限制时保存断点退出

请开始执行。"

    local session_log="$LOG_DIR/session-$(date +%Y%m%d_%H%M%S).log"
    local start_time=$(date +%s)
    
    _log "会话日志: $session_log"
    
    # macOS 兼容的超时实现（不使用 timeout 命令）
    # 在后台运行 claude，同时启动超时监控
    claude --print --dangerously-skip-permissions --max-turns $MAX_TURNS --model "${CLAUDE_MODEL:-claude-opus-4-5-20251101}" "$prompt" > "$session_log" 2>&1 &
    local claude_pid=$!
    
    # 超时监控进程
    (
        sleep $SESSION_TIMEOUT
        if kill -0 $claude_pid 2>/dev/null; then
            kill -TERM $claude_pid 2>/dev/null
            sleep 5
            kill -9 $claude_pid 2>/dev/null
        fi
    ) &
    local watchdog_pid=$!
    
    # 等待 claude 完成
    wait $claude_pid
    local code=$?
    
    # 清理 watchdog
    kill $watchdog_pid 2>/dev/null
    wait $watchdog_pid 2>/dev/null
    
    local end_time=$(date +%s)
    local duration=$((end_time - start_time))
    
    if [ $code -eq 0 ]; then
        _log "会话结束 (耗时: ${duration}s)"
        local current_status=$(get_json "['status']")
        [ "$current_status" = "running" ] && set_json "d['status']='continue'"
        return 0
    fi
    
    # 检查是否超时（被 watchdog 杀死）
    if [ $duration -ge $SESSION_TIMEOUT ]; then
        _log "WARN: 会话超时 (${duration}s >= ${SESSION_TIMEOUT}s)"
        set_json "d['status']='continue'; d['exit_reason']='session_timeout'"
        set_json "d['errors'].append({'type': 'timeout', 'session': d['sessions']['count'], 'duration': $duration, 'time': '$(date -u +%Y-%m-%dT%H:%M:%SZ)'})"
        return 1
    fi
    
    _log "会话退出 (code: $code, 耗时: ${duration}s)"
    set_json "d['status']='continue'"
    
    # 检查限流
    if grep -qi "rate.limit\|429\|too.many.requests" "$session_log" 2>/dev/null; then
        _log "WARN: 检测到限流"
        return 2
    fi
    
    # 检查其他错误
    if grep -qi "error\|failed\|exception" "$session_log" 2>/dev/null; then
        local error_msg=$(grep -i "error\|failed\|exception" "$session_log" | head -1)
        _log "WARN: 检测到错误: $error_msg"
    fi
    
    return $code
}

_handle_rate_limit() {
    _log "WARN: 限流，等待 ${RATE_LIMIT_WAIT}s"
    sleep $RATE_LIMIT_WAIT
}

# 检查心跳是否超时
check_heartbeat_timeout() {
    local last_hb=$(get_json "['last_heartbeat']" 2>/dev/null)
    if [ -z "$last_hb" ]; then
        return 1  # 无心跳记录，不超时
    fi
    
    # 使用本地时间计算（与 Claude 保持一致）
    # Claude 可能用本地时间但加了 Z 后缀，所以我们也用本地时间解析
    local age=$(python3 -c "
from datetime import datetime
try:
    # 移除 Z 后缀，按本地时间解析
    hb_str = '$last_hb'.replace('Z', '').replace('+00:00', '')
    hb = datetime.fromisoformat(hb_str)
    now = datetime.now()
    print(int((now - hb).total_seconds()))
except:
    print(99999)
" 2>/dev/null || echo 99999)
    
    if [ "$age" -gt "$HEARTBEAT_TIMEOUT" ]; then
        _log "WARN: 心跳超时 (${age}s > ${HEARTBEAT_TIMEOUT}s)"
        return 0  # 超时
    fi
    return 1  # 未超时
}

cmd_stop() {
    [ ! -f "$PID_FILE" ] && { echo "⚠️  未运行"; return; }
    local pid=$(cat "$PID_FILE")
    kill "$pid" 2>/dev/null
    sleep 2
    kill -9 "$pid" 2>/dev/null
    rm -f "$PID_FILE"
    echo "✅ 已停止"
}

cmd_pause() {
    [ ! -f "$STATE_FILE" ] && { echo "❌ 未初始化"; exit 1; }
    [ ! -f "$PID_FILE" ] && { echo "⚠️  未运行"; return; }
    
    set_json "d['status']='paused'"
    echo "⏸️  已暂停（完成当前会话后生效）"
    echo "   使用 '$SCRIPT_NAME start' 恢复"
}

cmd_status() {
    echo "=========================================="
    echo "📊 状态"
    echo "=========================================="
    
    local state=$(detect_project_state)
    
    case "$state" in
        running)
            local pid=$(cat "$PID_FILE")
            echo "守护进程: ✅ 运行中 (PID: $pid)"
            # 显示进程运行时间
            local start_time=$(ps -p $pid -o lstart= 2>/dev/null)
            [ -n "$start_time" ] && echo "启动时间: $start_time"
            ;;
        existing_state)
            echo "守护进程: ⏹️  未运行 (有断点可继续)"
            ;;
        new_with_docs)
            echo "守护进程: ⏹️  未运行 (检测到项目文档)"
            ;;
        new_empty)
            echo "守护进程: ⏹️  未运行 (空项目)"
            ;;
    esac
    
    [ ! -f "$STATE_FILE" ] && { echo ""; echo "使用 '$SCRIPT_NAME start' 开始"; return; }
    
    echo ""
    python3 << EOF
import json
from datetime import datetime, timezone

with open('$STATE_FILE') as f:
    s = json.load(f)

print(f"项目: {s['project']['name']}")
print(f"状态: {s['status']}")
print(f"阶段: {s['workflow']['current_phase']}")
print(f"会话: {s['sessions'].get('count', 0)} 次")

# 断点
task = s.get('current_task', {})
if task.get('checkpoint'):
    cp = task['checkpoint']
    if isinstance(cp, dict):
        print(f"断点: {cp.get('step', 'N/A')}")
    else:
        print(f"断点: {cp}")

# 心跳 - 使用本地时间计算（与 Claude 保持一致）
hb = s.get('last_heartbeat')
if hb:
    try:
        # 移除 Z 后缀，按本地时间解析
        hb_str = hb.replace('Z', '').replace('+00:00', '')
        hb_time = datetime.fromisoformat(hb_str)
        age = int((datetime.now() - hb_time).total_seconds())
        print(f"心跳: {age}s 前")
    except:
        pass

# 错误
errors = s.get('errors', [])
if errors:
    print(f"错误: {len(errors)} 个")
    for e in errors[-3:]:
        if isinstance(e, dict):
            print(f"  - {e.get('type', 'unknown')}: session {e.get('session', '?')}")
EOF
    
    [ -f "$REQUIREMENT_FILE" ] && { echo ""; echo "需求: $(head -1 "$REQUIREMENT_FILE")"; }
    
    echo ""
    echo "最近日志:"
    tail -5 "$LOG_DIR/daemon.log" 2>/dev/null || echo "  (无)"
    
    # 显示最新会话日志状态
    local latest_session=$(ls -t "$LOG_DIR"/session-*.log 2>/dev/null | head -1)
    if [ -n "$latest_session" ]; then
        local size=$(wc -c < "$latest_session" 2>/dev/null | tr -d ' ')
        local lines=$(wc -l < "$latest_session" 2>/dev/null | tr -d ' ')
        echo ""
        echo "最新会话: $(basename "$latest_session") (${size}B, ${lines}行)"
    fi
}

cmd_logs() {
    [ ! -f "$LOG_DIR/daemon.log" ] && { echo "❌ 无日志"; exit 1; }
    echo "📜 实时日志 (Ctrl+C 退出)"
    tail -f "$LOG_DIR/daemon.log"
}

cmd_reset() {
    cmd_stop 2>/dev/null
    rm -rf "$PROJECT_DIR/$STATE_DIR"
    echo "✅ 已重置"
}

# ============================================
# 入口
# ============================================

case "${1:-help}" in
    start)   cmd_start "$2" ;;
    stop)    cmd_stop ;;
    pause)   cmd_pause ;;
    status)  cmd_status ;;
    logs)    cmd_logs ;;
    reset)   cmd_reset ;;
    help|-h) cmd_help ;;
    *)       echo "❌ 未知命令: $1"; cmd_help; exit 1 ;;
esac
