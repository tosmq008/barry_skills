#!/bin/bash
# adaptive-dev - 自适应持续开发守护脚本 v1.0
# 智能分析项目状态，动态调度多 Agent，持续迭代直到可用

VERSION="1.0.0"
SCRIPT_NAME="adaptive-dev"

# ============================================
# 配置
# ============================================
STATE_DIR=".dev-state"
MAX_TURNS=50
MIN_INTERVAL=60
MAX_INTERVAL=120
RATE_LIMIT_WAIT=300
MAX_ERRORS=5
SESSION_TIMEOUT=1800
HEARTBEAT_TIMEOUT=1800
CLAUDE_MODEL="${CLAUDE_MODEL:-claude-sonnet-4-20250514}"

# Skill 路径 (支持自定义)
SKILL_DIR="${SKILL_DIR:-$HOME/.claude/skills/adaptive-dev-engine}"

# 路径
PROJECT_DIR="$(pwd)"
STATE_FILE="$PROJECT_DIR/$STATE_DIR/state.json"
PID_FILE="$PROJECT_DIR/$STATE_DIR/daemon.pid"
LOG_DIR="$PROJECT_DIR/$STATE_DIR/logs"
REQUIREMENT_FILE="$PROJECT_DIR/$STATE_DIR/requirement.txt"

# ============================================
# 工具函数
# ============================================

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

get_json() {
    python3 -c "import json; print(json.load(open('$STATE_FILE'))$1)" 2>/dev/null
}

set_json() {
    python3 << EOF
import json
from datetime import datetime, timezone
with open('$STATE_FILE', 'r') as f:
    d = json.load(f)
$1
d['last_heartbeat'] = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')
with open('$STATE_FILE', 'w') as f:
    json.dump(d, f, indent=2, ensure_ascii=False)
EOF
}

# 检测项目状态
detect_project_state() {
    # 返回: running | has_state | has_docs | empty

    # 1. 检查是否已在运行
    if [ -f "$PID_FILE" ] && ps -p "$(cat "$PID_FILE" 2>/dev/null)" &>/dev/null; then
        echo "running"
        return
    fi

    # 2. 检查是否有状态文件
    if [ -f "$STATE_FILE" ]; then
        echo "has_state"
        return
    fi

    # 3. 检查是否有项目文档
    if [ -d "docs/prd" ] && ls docs/prd/*.md &>/dev/null; then
        echo "has_docs"
        return
    fi

    if [ -f "PRD.md" ] || [ -f "requirements.md" ] || [ -f "README.md" ]; then
        echo "has_docs"
        return
    fi

    # 4. 检查是否有代码目录 (常见项目结构)
    if [ -d "src" ] || [ -d "client" ] || [ -d "admin" ] || [ -d "app" ] || \
       [ -d "backend" ] || [ -d "frontend" ] || [ -d "server" ] || [ -d "api" ] || \
       [ -d "lib" ] || [ -d "packages" ] || [ -d "modules" ]; then
        echo "has_docs"
        return
    fi

    # 5. 检查是否有项目配置文件 (各种语言/框架)
    if [ -f "package.json" ] || [ -f "pyproject.toml" ] || [ -f "requirements.txt" ] || \
       [ -f "Cargo.toml" ] || [ -f "go.mod" ] || [ -f "pom.xml" ] || [ -f "build.gradle" ] || \
       [ -f "Gemfile" ] || [ -f "composer.json" ] || [ -f "Makefile" ] || [ -f "CMakeLists.txt" ]; then
        echo "has_docs"
        return
    fi

    # 6. 检查是否有代码文件 (至少有一个)
    if ls *.py *.js *.ts *.go *.rs *.java *.rb *.php *.c *.cpp *.h 2>/dev/null | head -1 &>/dev/null; then
        echo "has_docs"
        return
    fi

    echo "empty"
}

# ============================================
# 命令
# ============================================

cmd_help() {
    cat << EOF
$SCRIPT_NAME v$VERSION - 自适应持续开发引擎

用法:
  $SCRIPT_NAME start [需求描述]    启动持续开发
  $SCRIPT_NAME stop                停止
  $SCRIPT_NAME pause               暂停
  $SCRIPT_NAME status              查看状态
  $SCRIPT_NAME logs                实时日志
  $SCRIPT_NAME reset               重置

自动判断逻辑:
  - 已在运行 → 提示已运行
  - 有状态文件 → 从断点继续
  - 有项目文档 → 基于现有项目继续
  - 空项目 → 需要传入需求描述

示例:
  # 空项目，从需求开始
  $SCRIPT_NAME start "一个待办事项App，支持增删改查"

  # 已有项目或暂停后继续
  $SCRIPT_NAME start

环境变量:
  CLAUDE_MODEL    使用的模型 (默认: claude-sonnet-4-20250514)

EOF
}

cmd_start() {
    local requirement="$1"
    local project_name="$(basename "$PROJECT_DIR")"

    # 检查依赖
    command -v python3 &>/dev/null || { echo "❌ 需要 python3"; exit 1; }
    command -v claude &>/dev/null || { echo "❌ 需要 claude CLI"; exit 1; }

    # 自动判断状态
    local state=$(detect_project_state)

    case "$state" in
        running)
            local pid=$(cat "$PID_FILE")
            echo "⚠️  已在运行 (PID: $pid)"
            echo "   使用 '$SCRIPT_NAME status' 查看状态"
            echo "   使用 '$SCRIPT_NAME stop' 停止"
            exit 1
            ;;

        has_state)
            echo "🔄 检测到断点，从上次继续..."
            project_name=$(get_json "['project']['name']" 2>/dev/null || echo "$project_name")

            # 如果是 paused 状态，自动恢复
            local current_status=$(get_json "['status']")
            if [ "$current_status" = "paused" ]; then
                echo "   (从暂停状态恢复)"
                set_json "d['status']='continue'"
            fi

            _do_start "$project_name"
            ;;

        has_docs)
            echo "📂 检测到现有项目，基于现有内容继续..."
            _init_state "$project_name" ""
            _do_start "$project_name"
            ;;

        empty)
            if [ -z "$requirement" ]; then
                echo "❌ 空项目需要提供需求描述"
                echo ""
                echo "用法: $SCRIPT_NAME start \"需求描述\""
                echo ""
                echo "示例:"
                echo "  $SCRIPT_NAME start \"一个待办事项App，支持创建、完成、删除任务\""
                exit 1
            fi
            echo "🆕 新项目，从需求开始..."
            _init_state "$project_name" "$requirement"
            _do_start "$project_name"
            ;;
    esac
}

_init_state() {
    local name="$1"
    local requirement="$2"

    mkdir -p "$PROJECT_DIR/$STATE_DIR"/{logs,checkpoints,locks}

    local ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    if [ -n "$requirement" ]; then
        echo "$requirement" > "$REQUIREMENT_FILE"
    fi

    cat > "$STATE_FILE" << EOF
{
  "version": "$VERSION",
  "project": {
    "name": "$name",
    "path": "$PROJECT_DIR",
    "type": "unknown",
    "created_at": "$ts"
  },
  "health": {
    "score": 0,
    "breakdown": {
      "requirements": 0,
      "code": 0,
      "tests": 0,
      "runnable": 0,
      "quality": 0
    },
    "usable": false,
    "target": 80,
    "assessed_at": null,
    "history": []
  },
  "status": "ready",
  "exit_reason": null,
  "current_action": null,
  "agent_coordination": {
    "active_agents": [],
    "completed_agents": [],
    "pending_sync": false
  },
  "action_history": [],
  "decision_log": [],
  "blockers": [],
  "errors": [],
  "sessions": {
    "count": 0,
    "total_turns": 0,
    "current_session": null
  },
  "last_heartbeat": "$ts",
  "metrics": {
    "total_duration_seconds": 0,
    "avg_health_delta_per_session": 0,
    "parallel_executions": 0
  }
}
EOF
}

_do_start() {
    local name="$1"

    echo "🚀 启动自适应持续开发: $name"
    echo "   项目目录: $PROJECT_DIR"
    echo "   模型: $CLAUDE_MODEL"

    # 启动守护进程
    _start_daemon &
    local pid=$!
    echo $pid > "$PID_FILE"

    sleep 2
    if ps -p $pid &>/dev/null; then
        echo ""
        echo "✅ 已启动 (PID: $pid)"
        echo ""
        echo "常用命令:"
        echo "  $SCRIPT_NAME status  查看状态"
        echo "  $SCRIPT_NAME logs    实时日志"
        echo "  $SCRIPT_NAME stop    停止"
    else
        echo "❌ 启动失败"
        tail -5 "$LOG_DIR/daemon.log" 2>/dev/null
        exit 1
    fi
}

_start_daemon() {
    exec >> "$LOG_DIR/daemon.log" 2>&1

    log "=========================================="
    log "守护进程启动 v$VERSION"
    log "模型: $CLAUDE_MODEL"
    log "=========================================="

    trap 'log "收到终止信号"; exit 0' SIGTERM SIGINT

    local errors=0
    local rate_limit_count=0

    while true; do
        [ ! -f "$STATE_FILE" ] && { log "ERROR: 状态文件丢失"; sleep 60; continue; }

        local status=$(get_json "['status']")
        local health_score=$(get_json "['health']['score']" 2>/dev/null || echo 0)

        log "当前状态: $status, 健康度: $health_score"

        case "$status" in
            ready|continue)
                _run_session
                local ret=$?

                if [ $ret -eq 2 ]; then
                    # 限流
                    rate_limit_count=$((rate_limit_count + 1))
                    local wait=$((RATE_LIMIT_WAIT * rate_limit_count))
                    [ $wait -gt 1800 ] && wait=1800
                    log "限流等待 ${wait}s (第 $rate_limit_count 次)"
                    sleep $wait
                elif [ $ret -ne 0 ]; then
                    errors=$((errors + 1))
                    [ $errors -ge $MAX_ERRORS ] && { log "ERROR: 连续错误过多"; exit 1; }
                else
                    errors=0
                    rate_limit_count=0
                fi

                # 检查是否完成
                local new_status=$(get_json "['status']")
                if [ "$new_status" = "completed" ]; then
                    log "🎉 项目达到可用状态！"
                    exit 0
                fi

                local wait=$((MIN_INTERVAL + RANDOM % (MAX_INTERVAL - MIN_INTERVAL + 1)))
                log "等待 ${wait}s"
                sleep $wait
                ;;

            running)
                # 检查心跳超时
                if _check_heartbeat_timeout; then
                    log "心跳超时，强制重启"
                    set_json "d['status']='continue'; d['exit_reason']='heartbeat_timeout'"
                    pkill -f "claude.*--max-turns" 2>/dev/null
                    sleep 5
                fi
                sleep 30
                ;;

            paused)
                log "已暂停，等待恢复"
                sleep 60
                ;;

            completed)
                log "🎉 项目完成！"
                exit 0
                ;;

            *)
                log "未知状态: $status"
                sleep 30
                ;;
        esac
    done
}

_run_session() {
    local health_score=$(get_json "['health']['score']" 2>/dev/null || echo 0)
    local session_count=$(get_json "['sessions']['count']" 2>/dev/null || echo 0)

    log "启动会话 #$((session_count + 1)) - 健康度: $health_score"

    # 更新状态
    set_json "d['status']='running'; d['sessions']['count']=d['sessions'].get('count',0)+1"

    # 读取需求
    local requirement=""
    [ -f "$REQUIREMENT_FILE" ] && requirement=$(cat "$REQUIREMENT_FILE")

    # 构建 prompt
    local prompt="你正在自适应持续开发模式下工作。

## 工作规范
请先读取 skill 文档了解工作流程:
cat $SKILL_DIR/SKILL.md

## 项目信息
- 项目名称: $(get_json "['project']['name']")
- 项目目录: $PROJECT_DIR
- 当前健康度: $health_score/100
- 目标健康度: 80/100

## 执行步骤
1. 执行项目健康度分析（SKILL.md 中的 Step 1）
2. 计算健康度评分（Step 2）
3. 根据健康度智能决策下一步行动（Step 3）
4. 调度合适的 Agent 执行（Step 4）
5. 更新状态文件

## 备用需求描述（仅当项目完全为空时使用）
$requirement

## 重要规则
1. 每次会话先分析健康度
2. 优先使用并行调度提高效率
3. 健康度 >= 80 即可用，不要过度优化
4. 每完成一步更新 .dev-state/state.json
5. 接近轮次限制时保存断点退出

请开始执行。"

    local session_log="$LOG_DIR/session-$(date +%Y%m%d_%H%M%S).log"
    local start_time=$(date +%s)

    log "会话日志: $session_log"

    # 启动 claude
    claude --print --dangerously-skip-permissions --max-turns $MAX_TURNS --model "$CLAUDE_MODEL" "$prompt" > "$session_log" 2>&1 &
    local claude_pid=$!

    # 超时监控
    (
        sleep $SESSION_TIMEOUT
        if kill -0 $claude_pid 2>/dev/null; then
            kill -TERM $claude_pid 2>/dev/null
            sleep 5
            kill -9 $claude_pid 2>/dev/null
        fi
    ) &
    local watchdog_pid=$!

    # 等待完成
    wait $claude_pid
    local code=$?

    # 清理 watchdog
    kill $watchdog_pid 2>/dev/null
    wait $watchdog_pid 2>/dev/null

    local end_time=$(date +%s)
    local duration=$((end_time - start_time))

    if [ $code -eq 0 ]; then
        log "会话结束 (耗时: ${duration}s)"
        local current_status=$(get_json "['status']")
        [ "$current_status" = "running" ] && set_json "d['status']='continue'"
        return 0
    fi

    # 检查超时
    if [ $duration -ge $SESSION_TIMEOUT ]; then
        log "会话超时 (${duration}s >= ${SESSION_TIMEOUT}s)"
        set_json "d['status']='continue'; d['exit_reason']='session_timeout'"
        return 1
    fi

    log "会话退出 (code: $code, 耗时: ${duration}s)"
    set_json "d['status']='continue'"

    # 检查限流
    if grep -qi "rate.limit\|429\|too.many.requests" "$session_log" 2>/dev/null; then
        log "检测到限流"
        return 2
    fi

    return $code
}

_check_heartbeat_timeout() {
    local last_hb=$(get_json "['last_heartbeat']" 2>/dev/null)
    [ -z "$last_hb" ] && return 1

    local age=$(python3 -c "
from datetime import datetime, timezone
try:
    hb_str = '$last_hb'.replace('Z', '+00:00')
    hb = datetime.fromisoformat(hb_str)
    now = datetime.now(timezone.utc)
    print(int((now - hb).total_seconds()))
except:
    print(99999)
" 2>/dev/null || echo 99999)

    [ "$age" -gt "$HEARTBEAT_TIMEOUT" ]
}

cmd_stop() {
    [ ! -f "$PID_FILE" ] && { echo "⚠️  未运行"; return; }
    local pid=$(cat "$PID_FILE")
    kill "$pid" 2>/dev/null
    sleep 2
    kill -9 "$pid" 2>/dev/null
    rm -f "$PID_FILE"
    echo "✅ 已停止"
}

cmd_pause() {
    [ ! -f "$STATE_FILE" ] && { echo "❌ 未初始化"; exit 1; }
    [ ! -f "$PID_FILE" ] && { echo "⚠️  未运行"; return; }

    set_json "d['status']='paused'; d['exit_reason']='user_pause'"
    echo "⏸️  已暂停（完成当前会话后生效）"
    echo "   使用 '$SCRIPT_NAME start' 恢复"
}

cmd_status() {
    echo "=========================================="
    echo "📊 自适应持续开发状态"
    echo "=========================================="

    local state=$(detect_project_state)

    case "$state" in
        running)
            local pid=$(cat "$PID_FILE")
            echo "守护进程: ✅ 运行中 (PID: $pid)"
            ;;
        has_state)
            echo "守护进程: ⏹️  未运行 (有断点可继续)"
            ;;
        has_docs)
            echo "守护进程: ⏹️  未运行 (检测到项目文档)"
            ;;
        empty)
            echo "守护进程: ⏹️  未运行 (空项目)"
            ;;
    esac

    [ ! -f "$STATE_FILE" ] && { echo ""; echo "使用 '$SCRIPT_NAME start' 开始"; return; }

    echo ""
    python3 << 'EOF'
import json
from datetime import datetime

with open('.dev-state/state.json') as f:
    s = json.load(f)

print(f"项目: {s['project']['name']}")
print(f"状态: {s['status']}")

# 健康度
h = s.get('health', {})
print(f"\n健康度: {h.get('score', 0)}/100 {'✅ 可用' if h.get('usable') else '🔄 开发中'}")
if h.get('breakdown'):
    b = h['breakdown']
    print(f"  需求: {b.get('requirements', 0)}/20")
    print(f"  代码: {b.get('code', 0)}/25")
    print(f"  测试: {b.get('tests', 0)}/20")
    print(f"  运行: {b.get('runnable', 0)}/20")
    print(f"  质量: {b.get('quality', 0)}/15")

# 会话
print(f"\n会话: {s['sessions'].get('count', 0)} 次")

# 当前行动
if s.get('current_action'):
    ca = s['current_action']
    print(f"当前行动: {ca.get('type', 'N/A')}")
    if ca.get('agents'):
        print(f"  Agent: {', '.join(ca['agents'])}")

# 心跳
hb = s.get('last_heartbeat')
if hb:
    try:
        from datetime import timezone
        hb_str = hb.replace('Z', '+00:00')
        hb_time = datetime.fromisoformat(hb_str)
        now = datetime.now(timezone.utc)
        age = int((now - hb_time).total_seconds())
        print(f"\n心跳: {age}s 前")
    except:
        pass

# 错误
errors = s.get('errors', [])
if errors:
    print(f"\n错误: {len(errors)} 个")
EOF

    echo ""
    echo "最近日志:"
    tail -5 "$LOG_DIR/daemon.log" 2>/dev/null || echo "  (无)"
}

cmd_logs() {
    [ ! -f "$LOG_DIR/daemon.log" ] && { echo "❌ 无日志"; exit 1; }
    echo "📜 实时日志 (Ctrl+C 退出)"
    tail -f "$LOG_DIR/daemon.log"
}

cmd_reset() {
    cmd_stop 2>/dev/null
    rm -rf "$PROJECT_DIR/$STATE_DIR"
    echo "✅ 已重置"
}

# ============================================
# 入口
# ============================================

case "${1:-help}" in
    start)   cmd_start "$2" ;;
    stop)    cmd_stop ;;
    pause)   cmd_pause ;;
    status)  cmd_status ;;
    logs)    cmd_logs ;;
    reset)   cmd_reset ;;
    help|-h|--help) cmd_help ;;
    *)       echo "❌ 未知命令: $1"; cmd_help; exit 1 ;;
esac
