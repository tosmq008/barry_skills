# Adaptive Dev Engine Configuration v2.0
# Copy to project/.dev-state/config.env to override per-project

# ============================================
# Session Control
# ============================================
STATE_DIR=".dev-state"
MAX_TURNS=40                    # Single session max turns (reduced from 50 for checkpoint margin)

# ============================================
# Rate Limiting Protection
# ============================================
MIN_INTERVAL=60                 # Min seconds between sessions
MAX_INTERVAL=120                # Max seconds between sessions (randomized)
RATE_LIMIT_WAIT=300             # Base wait after rate limit (seconds)
RATE_LIMIT_BACKOFF=1.5          # Exponential backoff multiplier

# ============================================
# Error Handling
# ============================================
MAX_ERRORS=5                    # Max consecutive errors before stop
SESSION_TIMEOUT=1800            # Single session timeout (seconds)

# ============================================
# Heartbeat & Recovery
# ============================================
HEARTBEAT_TIMEOUT=900           # Heartbeat timeout (reduced from 1800 for faster stall detection)

# ============================================
# Model & Skill
# ============================================
CLAUDE_MODEL="${CLAUDE_MODEL:-claude-sonnet-4-20250514}"
SKILL_DIR="${SKILL_DIR:-$HOME/.claude/skills/adaptive-dev-engine}"

# ============================================
# Git Integration
# ============================================
GIT_AUTO_COMMIT=true            # Auto git commit before each session
GIT_ROLLBACK_ON_FAILURE=false   # Revert on session failure

# ============================================
# Cost & Resource Control
# ============================================
MAX_TOTAL_SESSIONS=100          # Hard stop after N sessions (0=unlimited)
LOG_RETENTION_DAYS=7            # Delete logs older than N days
MAX_LOG_FILES=50                # Max session log files to keep

# ============================================
# Alerts (optional)
# ============================================
ALERT_WEBHOOK=""                # Slack/DingTalk webhook URL
